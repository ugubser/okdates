# OpenRouter configuration for the Cloud Functions date parser.
#
# Copy this file to `functions/.env` and fill in your real key. Firebase loads
# `functions/.env` into process.env for BOTH the emulator and `firebase deploy`,
# so this single file covers local dev and production.
#
# `functions/.env` is gitignored — never commit your real key.
# For stronger production secret handling, you can instead use Cloud Secret
# Manager via firebase-functions `defineSecret('OPENROUTER_API_KEY')`.

OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
OPENROUTER_MODEL=meta-llama/llama-4-maverick:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
